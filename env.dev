# =============================================================================
# VH-SRV-ORDERS DEVELOPMENT ENVIRONMENT
# =============================================================================
#
# There are 2 sections, App Code and Dev Infra.
# App code is what the code actually uses in common/config.go
# Dev infra is used by Taskfile and dev docker compose infra be it shared or standalone.
#
# Either dev infra mode you use, shared or standalone, you must set Dev Infra section
# and ensure it's in sync with App Code. Mainly DB_* and NATS_URL.
#
# In production, we only set App Code section.
#
# TODO (edo): Consolidate POSTGRES_* with DB_* as do NATS_URL and NATS_*
#

# =============================================================================
# DEV INFRA
# =============================================================================
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=orders

NATS_USER=user
NATS_PASSWORD=password
NATS_PORT=4222
NATS_MONITOR_PORT=8222

# =============================================================================
# APP CODE
# =============================================================================

APP_PORT=8185
APP_MODE=debug
APP_ENV=dev

PGHOST=localhost
PGPORT=5432
PGUSER=user
PGPASSWORD=password
PGDATABASE=orders

NATS_URL=nats://user:password@localhost:4222

KEYCLOAK_SERVER_URL=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=

SENDGRID_API_KEY=
SENTRY_DSN=

PROFILE_SERVICE_URL=http://localhost:7471
EVENTS_SERVICE_URL=http://localhost:7475
